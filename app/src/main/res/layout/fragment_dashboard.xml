<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true">

                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xin chào, Chủ trọ!"
                    android:textColor="@color/secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng quan"
                    style="@style/TextAppearance.App.Header" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/on_surface" />
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <!-- Main Financial Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_doanh_thu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="@color/primary"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng doanh thu tháng này"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:alpha="0.85" />

                <TextView
                    android:id="@+id/tv_doanh_thu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0 đ"
                    android:textColor="@color/white"
                    android:textSize="34sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/tv_thang_hien_tai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tháng --/----"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:alpha="0.7" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/white"
                    android:alpha="0.2"
                    android:layout_marginVertical="20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đã thu"
                            android:textColor="@color/white"
                            android:alpha="0.7"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_da_thu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 đ"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Còn nợ"
                            android:textColor="@color/white"
                            android:alpha="0.7"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_con_no"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 đ"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Room Stats Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tình trạng phòng &amp; Hóa đơn"
            android:textColor="@color/on_background"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:layout_marginBottom="24dp">

            <!-- Total Rooms -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                style="@style/Widget.App.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_room"
                        app:tint="@color/primary" />
                    <TextView
                        android:id="@+id/tv_tong_phong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/on_surface"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng số phòng"
                        android:textColor="@color/secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Occupied Rooms -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                style="@style/Widget.App.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_people"
                        app:tint="@color/status_occupied" />
                    <TextView
                        android:id="@+id/tv_dang_thue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/status_occupied"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đang cho thuê"
                        android:textColor="@color/secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Available Rooms -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                style="@style/Widget.App.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_room"
                        app:tint="@color/status_available" />
                    <TextView
                        android:id="@+id/tv_phong_trong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/status_available"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phòng đang trống"
                        android:textColor="@color/secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Unpaid Invoices -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                style="@style/Widget.App.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_receipt"
                        app:tint="@color/unpaid" />
                    <TextView
                        android:id="@+id/tv_hoa_don_chua_thu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="@color/unpaid"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hóa đơn chưa thu"
                        android:textColor="@color/secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <!-- Quick Actions Grid -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiện ích quản lý"
            android:textColor="@color/on_background"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="2"
            android:layout_marginBottom="24dp">

            <!-- Add Room -->
            <LinearLayout
                android:id="@+id/btn_them_phong"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/primary_light"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_room"
                        app:tint="@color/primary" />
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Phòng"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Add Tenant -->
            <LinearLayout
                android:id="@+id/btn_them_khach"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#E8F5E9"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_people"
                        app:tint="#4CAF50" />
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Khách thuê"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Invoice -->
            <LinearLayout
                android:id="@+id/btn_tao_hoa_don"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#FFF8E1"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_receipt"
                        app:tint="#FF8F00" />
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Hóa đơn"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Announcements -->
            <LinearLayout
                android:id="@+id/btn_post_notif"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#F3E5F5"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_backup"
                        app:tint="#9C27B0" />
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Thông báo"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Issues -->
            <LinearLayout
                android:id="@+id/btn_manage_issues"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#FFEBEE"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_settings"
                        app:tint="#E91E63" />
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Sự cố"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Stats -->
            <LinearLayout
                android:id="@+id/btn_view_stats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#E0F2F1"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_chart"
                        app:tint="#009688" />
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Báo cáo"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp" />
            </LinearLayout>
        </GridLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
